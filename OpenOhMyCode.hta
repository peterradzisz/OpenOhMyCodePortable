<!DOCTYPE html>
<html>
<head>
<title>OpenOhMyCode Portable</title>
<HTA:APPLICATION
    ID="OpenOhMyCode"
    APPLICATIONNAME="OpenOhMyCode Portable"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    CONTEXTMENU="yes"
    ICON=""
    INNERBORDER="no"
    MAXIMIZEBUTTON="yes"
    MINIMIZEBUTTON="yes"
    NAVIGABLE="no"
    SCROLL="no"
    SCROLLFLAT="no"
    SELECTION="no"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    VERSION="2.0"
    WINDOWSTATE="normal"
/>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    font-size: 16px;
    background: #1e1e1e;
    color: #cccccc;
}

/* Main container */
.container {
    width: 100%;
    height: 100%;
}

/* Sidebar */
.sidebar {
    position: absolute;
    left: 0;
    top: 0;
    width: 60px;
    height: 100%;
    background: #333333;
    border-right: 2px solid #555555;
}

.sidebar-item {
    width: 60px;
    height: 60px;
    text-align: center;
    line-height: 60px;
    cursor: pointer;
    color: #888888;
    font-size: 28px;
}

.sidebar-item:hover { color: #ffffff; background: #444444; }
.sidebar-item.active { color: #ffffff; background: #094771; }

/* Main content area */
.main-content {
    position: absolute;
    left: 60px;
    top: 0;
    right: 0;
    bottom: 0;
    background: #1e1e1e;
}

/* Header */
.header {
    height: 45px;
    background: #252526;
    border-bottom: 2px solid #555555;
    padding: 0 20px;
    line-height: 45px;
}

.header-title {
    font-size: 16px;
    color: #888888;
    text-transform: uppercase;
}

/* Scrollable content */
.content {
    position: absolute;
    top: 45px;
    bottom: 35px;
    left: 0;
    right: 0;
    overflow-y: auto;
    padding: 20px;
}

.panel { display: none; }
.panel.active { display: block; }

/* Sections */
.section {
    margin-bottom: 25px;
}

.section-title {
    font-size: 14px;
    color: #888888;
    text-transform: uppercase;
    padding-bottom: 10px;
    margin-bottom: 15px;
    border-bottom: 2px solid #555555;
}

/* Form elements */
.form-line {
    margin-bottom: 15px;
}

.form-line:after {
    content: "";
    display: table;
    clear: both;
}

label {
    display: block;
    font-size: 14px;
    color: #888888;
    margin-bottom: 5px;
}

input[type="text"], select {
    width: 350px;
    height: 36px;
    padding: 0 12px;
    background: #3c3c3c;
    border: 2px solid #555555;
    color: #cccccc;
    font-size: 16px;
    font-family: inherit;
}

input[type="text"]:focus, select:focus {
    border-color: #007acc;
    outline: none;
}

/* Buttons */
.btn {
    height: 36px;
    padding: 0 20px;
    border: none;
    font-size: 15px;
    font-family: inherit;
    cursor: pointer;
    color: #ffffff;
}

.btn-primary { background: #007acc; }
.btn-primary:hover { background: #0099ff; }
.btn-secondary { background: #555555; }
.btn-secondary:hover { background: #666666; }
.btn-success { background: #2d8c2d; }
.btn-success:hover { background: #3ca53c; }
.btn-danger { background: #c42b1c; }
.btn-danger:hover { background: #e03c2c; }

.btn-row {
    margin-top: 10px;
}

.btn-row .btn {
    margin-right: 10px;
    margin-bottom: 10px;
}

/* Status bar */
.status-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35px;
    background: #007acc;
    padding: 0 20px;
    line-height: 35px;
    font-size: 13px;
    color: #ffffff;
}

.status-bar span {
    margin-right: 30px;
}

/* Output */
.output-box {
    margin-top: 20px;
    border: 2px solid #555555;
    background: #1e1e1e;
}

.output-header {
    background: #333333;
    padding: 8px 12px;
    border-bottom: 2px solid #555555;
}

.output-title {
    font-size: 12px;
    color: #888888;
    text-transform: uppercase;
}

.output-content {
    height: 180px;
    overflow-y: auto;
    padding: 12px;
    font-family: Consolas, monospace;
    font-size: 16px;
    line-height: 1.6;
    white-space: pre-wrap;
}

.success { color: #4ec9b0; }
.error { color: #f14c4c; }
.info { color: #3794ff; }
.warn { color: #cca700; }

/* Info list */
.info-list {
    border: 2px solid #555555;
    background: #252526;
}

.info-row {
    padding: 10px 15px;
    border-bottom: 1px solid #555555;
}

.info-row:last-child { border-bottom: none; }

.info-label {
    display: inline-block;
    width: 100px;
    color: #888888;
}

.info-value {
    font-family: Consolas, monospace;
    color: #cccccc;
}

/* Card */
.card {
    border: 2px solid #555555;
    background: #252526;
    padding: 15px;
    margin-bottom: 15px;
}

.card-title {
    font-size: 18px;
    color: #cccccc;
    margin-bottom: 8px;
}

.card-text {
    font-size: 14px;
    color: #888888;
    line-height: 1.5;
}

/* Status dots */
.status-row {
    padding: 8px 0;
}

.status-dot {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-right: 10px;
    vertical-align: middle;
}

.status-dot.ok { background: #4ec9b0; }
.status-dot.warn { background: #cca700; }
</style>
</head>
<body>
<div class="container">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-item active" onclick="showPanel('main', this)">&#9654;</div>
        <div class="sidebar-item" onclick="showPanel('worktree', this)">&#9874;</div>
        <div class="sidebar-item" onclick="showPanel('playwright', this)">&#9881;</div>
        <div class="sidebar-item" onclick="showPanel('settings', this)">&#9881;</div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="header">
            <span class="header-title" id="headerTitle">Start</span>
        </div>

        <div class="content">
            <!-- Main Panel -->
            <div id="panel-main" class="panel active">
                <div class="section">
                    <div class="section-title">Start OpenCode</div>
                    <div class="form-line">
                        <label>Project Folder</label>
                        <input type="text" id="projectPath" placeholder="Enter path...">
                        <button class="btn btn-secondary" onclick="browseFolder()">Browse</button>
                        <button class="btn btn-primary" onclick="runOpenCode()">Start</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-title">Quick Actions</div>
                    <div class="btn-row">
                        <button class="btn btn-secondary" onclick="openInCurrentFolder()">This Folder</button>
                        <button class="btn btn-secondary" onclick="openConfig()">Open Config</button>
                        <button class="btn btn-secondary" onclick="checkNode()">Check Node.js</button>
                        <button class="btn btn-secondary" onclick="checkOpenCode()">Check OpenCode</button>
                    </div>
                </div>

                <div class="output-box">
                    <div class="output-header"><span class="output-title">Output</span></div>
                    <div class="output-content" id="output"></div>
                </div>
            </div>

            <!-- Worktree Panel -->
            <div id="panel-worktree" class="panel">
                <div class="section">
                    <div class="section-title">Create Worktree</div>
                    <div class="form-line">
                        <label>Name</label>
                        <input type="text" id="wtName" placeholder="feature-auth" style="width:200px;">
                        <select id="wtAgent" style="width:150px;">
                            <option value="">No Agent</option>
                            <option value="sisyphus">sisyphus</option>
                            <option value="hephaestus">hephaestus</option>
                            <option value="oracle">oracle</option>
                            <option value="librarian">librarian</option>
                            <option value="explore">explore</option>
                        </select>
                        <button class="btn btn-success" onclick="createWorktree()">Create</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-title">Actions</div>
                    <div class="btn-row">
                        <button class="btn btn-primary" onclick="listWorktrees()">List All</button>
                        <button class="btn btn-primary" onclick="showStatus()">Status</button>
                        <button class="btn btn-secondary" onclick="checkConflicts()">Check Conflicts</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-title">Merge / Delete</div>
                    <div class="form-line">
                        <label>Worktree Name</label>
                        <input type="text" id="wtMergeName" placeholder="feature-auth" style="width:200px;">
                        <button class="btn btn-secondary" onclick="mergeWorktree()">Merge</button>
                        <button class="btn btn-danger" onclick="deleteWorktree()">Delete</button>
                    </div>
                    <div class="btn-row">
                        <button class="btn btn-secondary" onclick="cleanupMerged()">Cleanup Merged</button>
                        <button class="btn btn-danger" onclick="cleanupAll()">Cleanup All</button>
                    </div>
                </div>

                <div class="output-box">
                    <div class="output-header"><span class="output-title">Output</span></div>
                    <div class="output-content" id="output-wt"></div>
                </div>
            </div>

            <!-- Playwright Panel -->
            <div id="panel-playwright" class="panel">
                <div class="section">
                    <div class="section-title">Browser Automation</div>
                    <div class="card">
                        <div class="card-title">Playwright with Chromium</div>
                        <div class="card-text">Install Chromium browser for automated testing. (~135MB)</div>
                    </div>
                    <div class="btn-row">
                        <button class="btn btn-success" onclick="installPlaywright()">Install Chromium</button>
                        <button class="btn btn-secondary" onclick="checkPlaywright()">Check Status</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-title">Status</div>
                    <div class="status-row">
                        <span class="status-dot" id="pwNpmStatus"></span>
                        <span id="pwNpmText">Checking...</span>
                    </div>
                    <div class="status-row">
                        <span class="status-dot" id="pwBrowserStatus"></span>
                        <span id="pwBrowserText">Checking...</span>
                    </div>
                </div>

                <div class="output-box">
                    <div class="output-header"><span class="output-title">Output</span></div>
                    <div class="output-content" id="output-pw"></div>
                </div>
            </div>

            <!-- Settings Panel -->
            <div id="panel-settings" class="panel">
                <div class="section">
                    <div class="section-title">Paths</div>
                    <div class="info-list">
                        <div class="info-row">
                            <span class="info-label">Root</span>
                            <span class="info-value" id="pathRoot"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Node.js</span>
                            <span class="info-value" id="pathNode"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">App</span>
                            <span class="info-value" id="pathApp"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Config</span>
                            <span class="info-value" id="pathConfig"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Browsers</span>
                            <span class="info-value" id="pathBrowsers"></span>
                        </div>
                    </div>
                </div>

                <div class="section">
                    <div class="section-title">About</div>
                    <div class="card">
                        <div class="card-title">OpenOhMyCode Portable</div>
                        <div class="card-text">Version 2.0 - Portable OpenCode + oh-my-opencode bundle<br>Run multiple AI agents in parallel with git worktree isolation.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="status-bar">
            <span>Ready</span>
            <span>OpenOhMyCode Portable v2.0</span>
        </div>
    </div>
</div>

<script language="VBScript">
Dim fso, shell
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")

Function GetPortableRoot()
    Dim path
    path = Replace(location.pathname, "/", "\")
    path = Replace(path, "OpenOhMyCode.hta", "")
    If Left(path, 1) = "\" Then path = Mid(path, 2)
    GetPortableRoot = path
End Function

Function RunCommand(cmd)
    Dim exec, output
    On Error Resume Next
    Set exec = shell.Exec(cmd)
    If Err.Number <> 0 Then
        RunCommand = "Error: " & Err.Description
        Exit Function
    End If
    output = ""
    Do While exec.Status = 0 Or Not exec.StdOut.AtEndOfStream
        If Not exec.StdOut.AtEndOfStream Then
            output = output & exec.StdOut.ReadLine & vbCrLf
        End If
    Loop
    Do While Not exec.StdErr.AtEndOfStream
        output = output & exec.StdErr.ReadLine & vbCrLf
    Loop
    RunCommand = output
End Function

Function PathExists(path)
    PathExists = fso.FolderExists(path) Or fso.FileExists(path)
End Function

Function BrowseFolder()
    Dim folderDialog, result
    On Error Resume Next
    Set folderDialog = CreateObject("Shell.Application")
    Set result = folderDialog.BrowseForFolder(0, "Select Project Folder", 0)
    If Err.Number = 0 And Not result Is Nothing Then
        BrowseFolder = result.Self.Path
    Else
        BrowseFolder = ""
    End If
End Function
</script>

<script language="JScript">
var portableRoot = '';
var nodeHome = '';
var appHome = '';
var configDir = '';
var browsersPath = '';
var currentOutput = 'output';

function init() {
    portableRoot = GetPortableRoot();
    if (portableRoot.charAt(portableRoot.length - 1) == '\\') {
        portableRoot = portableRoot.substring(0, portableRoot.length - 1);
    }
    nodeHome = portableRoot + '\\nodejs';
    appHome = portableRoot + '\\app';
    configDir = portableRoot + '\\config';
    browsersPath = portableRoot + '\\browsers';
    
    document.getElementById('pathRoot').innerText = portableRoot;
    document.getElementById('pathNode').innerText = nodeHome;
    document.getElementById('pathApp').innerText = appHome;
    document.getElementById('pathConfig').innerText = configDir;
    document.getElementById('pathBrowsers').innerText = browsersPath;
    checkPlaywrightStatus();
}

function log(msg, type) {
    var output = document.getElementById(currentOutput);
    var line = document.createElement('div');
    if (type) line.className = type;
    line.innerText = msg;
    output.appendChild(line);
    output.scrollTop = output.scrollHeight;
}

function clearOutput() {
    document.getElementById(currentOutput).innerHTML = '';
}

function logInfo(msg) { log('[INFO] ' + msg, 'info'); }
function logSuccess(msg) { log('[OK] ' + msg, 'success'); }
function logError(msg) { log('[ERROR] ' + msg, 'error'); }
function logWarn(msg) { log('[WARN] ' + msg, 'warn'); }

function showPanel(name, element) {
    var panels = ['main', 'worktree', 'playwright', 'settings'];
    var titles = { main: 'Start', worktree: 'Worktrees', playwright: 'Playwright', settings: 'Settings' };
    var outputs = { main: 'output', worktree: 'output-wt', playwright: 'output-pw', settings: 'output' };
    
    try {
        for (var i = 0; i < panels.length; i++) {
            var pnl = document.getElementById('panel-' + panels[i]);
            if (pnl) pnl.className = 'panel';
        }
        var items = document.querySelectorAll('.sidebar-item');
        for (var i = 0; i < items.length; i++) {
            items[i].className = 'sidebar-item';
        }
        var activePanel = document.getElementById('panel-' + name);
        if (activePanel) activePanel.className = 'panel active';
        if (element) element.className = 'sidebar-item active';
        var titleEl = document.getElementById('headerTitle');
        if (titleEl) titleEl.innerText = titles[name];
        currentOutput = outputs[name];
    } catch(e) {
        alert('Error: ' + e.message);
    }
}

function browseFolder() {
    var folder = BrowseFolder();
    if (folder) document.getElementById('projectPath').value = folder;
}

function runOpenCode() {
    var path = document.getElementById('projectPath').value;
    if (!path) { logError('Enter project path'); return; }
    if (!PathExists(path)) { logError('Folder not found'); return; }
    logInfo('Starting OpenCode...');
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\opencode-ai\\bin\\opencode"';
    shell.CurrentDirectory = path;
    shell.Run('cmd /k "' + cmd + '"', 1, false);
    logSuccess('Started');
}

function openInCurrentFolder() { document.getElementById('projectPath').value = portableRoot; }
function openConfig() { shell.Run('explorer "' + configDir + '"', 1, false); }

function checkNode() {
    logInfo('Checking...');
    if (PathExists(nodeHome + '\\node.exe')) logSuccess('Found');
    else logError('Not found');
}

function checkOpenCode() {
    logInfo('Checking...');
    if (PathExists(appHome + '\\node_modules\\opencode-ai\\bin\\opencode')) logSuccess('Found');
    else logError('Not found');
}

function createWorktree() {
    var name = document.getElementById('wtName').value;
    var agent = document.getElementById('wtAgent').value;
    if (!name) { logError('Enter name'); return; }
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree create ' + name;
    if (agent) cmd += ' --agent ' + agent;
    log(RunCommand(cmd));
}

function listWorktrees() {
    log(RunCommand('"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree list'));
}

function showStatus() {
    log(RunCommand('"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree status'));
}

function checkConflicts() {
    log(RunCommand('"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree status --conflicts'));
}

function mergeWorktree() {
    var name = document.getElementById('wtMergeName').value;
    if (!name) { logError('Enter name'); return; }
    log(RunCommand('"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree merge ' + name + ' --yes'));
}

function deleteWorktree() {
    var name = document.getElementById('wtMergeName').value;
    if (!name) { logError('Enter name'); return; }
    log(RunCommand('"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup ' + name + ' --force'));
}

function cleanupMerged() {
    log(RunCommand('"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup --merged --force'));
}

function cleanupAll() {
    log(RunCommand('"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup --all --force'));
}

function checkPlaywrightStatus() {
    var npmStatus = document.getElementById('pwNpmStatus');
    var npmText = document.getElementById('pwNpmText');
    if (PathExists(appHome + '\\node_modules\\playwright')) {
        npmStatus.className = 'status-dot ok';
        npmText.innerText = 'Playwright npm: Installed';
    } else {
        npmStatus.className = 'status-dot warn';
        npmText.innerText = 'Playwright npm: Not installed';
    }
    var browserStatus = document.getElementById('pwBrowserStatus');
    var browserText = document.getElementById('pwBrowserText');
    if (PathExists(browsersPath)) {
        browserStatus.className = 'status-dot ok';
        browserText.innerText = 'Chromium: Installed';
    } else {
        browserStatus.className = 'status-dot warn';
        browserText.innerText = 'Chromium: Not installed';
    }
}

function installPlaywright() {
    logInfo('Installing...');
    var cmd = 'cmd /c "set PLAYWRIGHT_BROWSERS_PATH=' + browsersPath + ' && "' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\playwright\\cli.js" install chromium"';
    log(RunCommand(cmd));
    checkPlaywrightStatus();
}

function checkPlaywright() {
    logInfo('Checking...');
    checkPlaywrightStatus();
    if (PathExists(appHome + '\\node_modules\\playwright')) logSuccess('npm: OK');
    else logWarn('npm: Missing');
    if (PathExists(browsersPath)) logSuccess('Chromium: OK');
    else logWarn('Chromium: Missing');
}

window.onload = init;

function handleError(msg, url, line) {
    alert('Script Error:\n' + msg + '\nLine: ' + line);
    return true;
}
window.onerror = handleError;
</body>
</html>
