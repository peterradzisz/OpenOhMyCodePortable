<!DOCTYPE html>
<html>
<head>
<title>OpenOhMyCode Portable</title>
<HTA:APPLICATION
    ID="OpenOhMyCode"
    APPLICATIONNAME="OpenOhMyCode Portable"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    CONTEXTMENU="yes"
    ICON=""
    INNERBORDER="no"
    MAXIMIZEBUTTON="yes"
    MINIMIZEBUTTON="yes"
    NAVIGABLE="no"
    SCROLL="no"
    SCROLLFLAT="no"
    SELECTION="no"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    VERSION="2.0"
    WINDOWSTATE="normal"
/>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
    height: 100%;
    overflow: hidden;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    font-size: 13px;
    background: #1e1e1e;
    color: #cccccc;
}

/* Layout */
.app {
    width: 100%;
    height: 100%;
    display: table;
}

/* Sidebar */
.sidebar {
    width: 48px;
    height: 100%;
    background: #333333;
    border-right: 1px solid #3c3c3c;
    display: table-cell;
    vertical-align: top;
    padding-top: 8px;
}

.sidebar-item {
    width: 48px;
    height: 48px;
    text-align: center;
    line-height: 48px;
    cursor: pointer;
    color: #858585;
    font-size: 20px;
}

.sidebar-item:hover {
    color: #ffffff;
    background: #2a2d2e;
}

.sidebar-item.active {
    color: #ffffff;
    background: #094771;
}

/* Main Content */
.main {
    height: 100%;
    display: table-cell;
    vertical-align: top;
}

/* Header */
.header {
    height: 35px;
    background: #323233;
    border-bottom: 1px solid #3c3c3c;
    line-height: 35px;
    padding: 0 16px;
}

.header-title {
    font-size: 12px;
    font-weight: 600;
    color: #858585;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Content */
.content-area {
    height: calc(100% - 35px - 28px);
    overflow: auto;
    padding: 20px;
}

.panel {
    display: none;
}

.panel.active {
    display: block;
}

/* Sections */
.section {
    margin-bottom: 24px;
}

.section-header {
    padding-bottom: 8px;
    margin-bottom: 12px;
    border-bottom: 1px solid #3c3c3c;
}

.section-title {
    font-size: 12px;
    font-weight: 600;
    color: #858585;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Form */
.form-row {
    margin-bottom: 12px;
}

.form-row:after {
    content: "";
    display: table;
    clear: both;
}

.form-group {
    margin-bottom: 8px;
}

.form-group.inline {
    float: left;
    margin-right: 8px;
    margin-bottom: 0;
}

.form-group.inline-btn {
    float: left;
    margin-right: 8px;
    margin-bottom: 0;
    width: auto;
}

.form-label {
    display: block;
    font-size: 11px;
    color: #858585;
    margin-bottom: 4px;
}

.form-input, .form-select {
    width: 100%;
    height: 28px;
    padding: 0 10px;
    background: #3c3c3c;
    border: 1px solid #3c3c3c;
    color: #cccccc;
    font-family: inherit;
    font-size: 13px;
    outline: none;
}

.form-input:focus, .form-select:focus {
    border-color: #007acc;
}

.form-group.inline .form-input,
.form-group.inline .form-select {
    width: 200px;
}

.form-group.inline-btn .form-input {
    width: 350px;
}

/* Buttons */
.btn {
    height: 28px;
    padding: 0 16px;
    border: none;
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    color: #ffffff;
}

.btn-primary {
    background: #0e639c;
}

.btn-primary:hover {
    background: #1177bb;
}

.btn-secondary {
    background: #3c3c3c;
    color: #cccccc;
}

.btn-secondary:hover {
    background: #4e4e4e;
}

.btn-success {
    background: #1c6e1c;
}

.btn-success:hover {
    background: #2d8c2d;
}

.btn-danger {
    background: #c42b1c;
}

.btn-danger:hover {
    background: #d63a2a;
}

.btn-small {
    height: 24px;
    padding: 0 10px;
    font-size: 11px;
}

/* Button Grid */
.btn-grid {
    overflow: hidden;
}

.btn-grid .btn {
    float: left;
    margin: 0 8px 8px 0;
    min-width: 140px;
}

/* Status Bar */
.status-bar {
    height: 28px;
    background: #007acc;
    line-height: 28px;
    padding: 0 16px;
    font-size: 11px;
    color: #ffffff;
}

.status-bar span {
    margin-right: 24px;
}

/* Output Panel */
.output-panel {
    background: #1e1e1e;
    border: 1px solid #3c3c3c;
    margin-top: 16px;
}

.output-header {
    background: #252526;
    padding: 6px 12px;
    border-bottom: 1px solid #3c3c3c;
    overflow: hidden;
}

.output-title {
    font-size: 11px;
    color: #858585;
    text-transform: uppercase;
    float: left;
}

.output-content {
    height: 140px;
    overflow-y: auto;
    padding: 12px;
    font-family: Consolas, 'Courier New', monospace;
    font-size: 12px;
    line-height: 1.5;
    white-space: pre-wrap;
    background: #1e1e1e;
}

.success { color: #4ec9b0; }
.error { color: #f14c4c; }
.info { color: #3794ff; }
.warn { color: #cca700; }

/* Info List */
.info-list {
    background: #252526;
    border: 1px solid #3c3c3c;
}

.info-row {
    padding: 8px 12px;
    border-bottom: 1px solid #3c3c3c;
    overflow: hidden;
}

.info-row:last-child {
    border-bottom: none;
}

.info-label {
    float: left;
    width: 100px;
    color: #858585;
    font-size: 12px;
}

.info-value {
    float: left;
    color: #cccccc;
    font-family: Consolas, 'Courier New', monospace;
    font-size: 12px;
}

/* Card */
.card {
    background: #252526;
    border: 1px solid #3c3c3c;
    padding: 16px;
    margin-bottom: 16px;
}

.card-title {
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 8px;
}

.card-text {
    font-size: 12px;
    color: #858585;
    line-height: 1.6;
}

/* Status Check */
.status-check {
    background: #252526;
    border: 1px solid #3c3c3c;
    padding: 12px;
}

.status-row {
    margin-bottom: 8px;
}

.status-row:last-child {
    margin-bottom: 0;
}

.status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 8px;
}

.status-dot.ok { background: #4ec9b0; }
.status-dot.warn { background: #cca700; }
.status-dot.error { background: #f14c4c; }

/* Clear */
.clear { clear: both; }
</style>
</head>
<body>
<div class="app">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-item active" onclick="showPanel('main')" title="Start">&#9654;</div>
        <div class="sidebar-item" onclick="showPanel('worktree')" title="Worktrees">&#9632;</div>
        <div class="sidebar-item" onclick="showPanel('playwright')" title="Playwright">&#9881;</div>
        <div class="sidebar-item" onclick="showPanel('settings')" title="Settings">&#9993;</div>
    </div>

    <!-- Main Content -->
    <div class="main">
        <!-- Header -->
        <div class="header">
            <span class="header-title" id="headerTitle">Start</span>
        </div>

        <!-- Content Area -->
        <div class="content-area">
            <!-- Main Panel -->
            <div id="panel-main" class="panel active">
                <div class="section">
                    <div class="section-header"><span class="section-title">Start OpenCode</span></div>
                    <div class="form-row">
                        <div class="form-group inline-btn">
                            <label class="form-label">Project Folder</label>
                            <input type="text" class="form-input" id="projectPath" placeholder="Enter path...">
                        </div>
                        <div class="form-group inline" style="padding-top:20px;">
                            <button class="btn btn-secondary" onclick="browseFolder()">Browse</button>
                        </div>
                        <div class="form-group inline" style="padding-top:20px;">
                            <button class="btn btn-primary" onclick="runOpenCode()">Start</button>
                        </div>
                    </div>
                    <div class="clear"></div>
                </div>

                <div class="section">
                    <div class="section-header"><span class="section-title">Quick Actions</span></div>
                    <div class="btn-grid">
                        <button class="btn btn-secondary" onclick="openInCurrentFolder()">This Folder</button>
                        <button class="btn btn-secondary" onclick="openConfig()">Open Config</button>
                        <button class="btn btn-secondary" onclick="checkNode()">Check Node.js</button>
                        <button class="btn btn-secondary" onclick="checkOpenCode()">Check OpenCode</button>
                    </div>
                </div>

                <div class="output-panel">
                    <div class="output-header">
                        <span class="output-title">Output</span>
                        <button class="btn btn-secondary btn-small" style="float:right;margin-top:-3px;" onclick="clearOutput()">Clear</button>
                    </div>
                    <div class="output-content" id="output"></div>
                </div>
            </div>

            <!-- Worktree Panel -->
            <div id="panel-worktree" class="panel">
                <div class="section">
                    <div class="section-header"><span class="section-title">Create Worktree</span></div>
                    <div class="form-row">
                        <div class="form-group inline">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-input" id="wtName" placeholder="feature-auth">
                        </div>
                        <div class="form-group inline">
                            <label class="form-label">Agent</label>
                            <select class="form-select" id="wtAgent">
                                <option value="">None</option>
                                <option value="sisyphus">sisyphus</option>
                                <option value="hephaestus">hephaestus</option>
                                <option value="oracle">oracle</option>
                                <option value="librarian">librarian</option>
                                <option value="explore">explore</option>
                            </select>
                        </div>
                        <div class="form-group inline" style="padding-top:20px;">
                            <button class="btn btn-success" onclick="createWorktree()">Create</button>
                        </div>
                    </div>
                    <div class="clear"></div>
                </div>

                <div class="section">
                    <div class="section-header"><span class="section-title">Actions</span></div>
                    <div class="btn-grid">
                        <button class="btn btn-primary" onclick="listWorktrees()">List All</button>
                        <button class="btn btn-primary" onclick="showStatus()">Status</button>
                        <button class="btn btn-secondary" onclick="checkConflicts()">Check Conflicts</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header"><span class="section-title">Merge / Delete</span></div>
                    <div class="form-row">
                        <div class="form-group inline">
                            <label class="form-label">Worktree Name</label>
                            <input type="text" class="form-input" id="wtMergeName" placeholder="feature-auth">
                        </div>
                        <div class="form-group inline" style="padding-top:20px;">
                            <button class="btn btn-secondary" onclick="mergeWorktree()">Merge</button>
                        </div>
                        <div class="form-group inline" style="padding-top:20px;">
                            <button class="btn btn-danger" onclick="deleteWorktree()">Delete</button>
                        </div>
                    </div>
                    <div class="clear"></div>
                    <div style="margin-top:12px;">
                        <button class="btn btn-secondary" onclick="cleanupMerged()">Cleanup Merged</button>
                        <button class="btn btn-danger" onclick="cleanupAll()">Cleanup All</button>
                    </div>
                </div>

                <div class="output-panel">
                    <div class="output-header">
                        <span class="output-title">Output</span>
                        <button class="btn btn-secondary btn-small" style="float:right;margin-top:-3px;" onclick="clearOutput()">Clear</button>
                    </div>
                    <div class="output-content" id="output-wt"></div>
                </div>
            </div>

            <!-- Playwright Panel -->
            <div id="panel-playwright" class="panel">
                <div class="section">
                    <div class="section-header"><span class="section-title">Browser Automation</span></div>
                    <div class="card">
                        <div class="card-title">Playwright with Chromium</div>
                        <div class="card-text">Install Chromium browser for automated testing.<br>Download size: ~135MB</div>
                    </div>
                    <div style="margin-top:16px;">
                        <button class="btn btn-success" onclick="installPlaywright()">Install Chromium</button>
                        <button class="btn btn-secondary" onclick="checkPlaywright()">Check Status</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header"><span class="section-title">Status</span></div>
                    <div class="status-check">
                        <div class="status-row">
                            <span class="status-dot" id="pwNpmStatus"></span>
                            <span id="pwNpmText">Checking...</span>
                        </div>
                        <div class="status-row">
                            <span class="status-dot" id="pwBrowserStatus"></span>
                            <span id="pwBrowserText">Checking...</span>
                        </div>
                    </div>
                </div>

                <div class="output-panel">
                    <div class="output-header">
                        <span class="output-title">Output</span>
                        <button class="btn btn-secondary btn-small" style="float:right;margin-top:-3px;" onclick="clearOutput()">Clear</button>
                    </div>
                    <div class="output-content" id="output-pw"></div>
                </div>
            </div>

            <!-- Settings Panel -->
            <div id="panel-settings" class="panel">
                <div class="section">
                    <div class="section-header"><span class="section-title">Paths</span></div>
                    <div class="info-list">
                        <div class="info-row">
                            <span class="info-label">Root</span>
                            <span class="info-value" id="pathRoot"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Node.js</span>
                            <span class="info-value" id="pathNode"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">App</span>
                            <span class="info-value" id="pathApp"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Config</span>
                            <span class="info-value" id="pathConfig"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Browsers</span>
                            <span class="info-value" id="pathBrowsers"></span>
                        </div>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header"><span class="section-title">About</span></div>
                    <div class="card">
                        <div class="card-title">OpenOhMyCode Portable</div>
                        <div class="card-text">
                            Version 2.0<br>
                            Portable OpenCode + oh-my-opencode bundle<br><br>
                            Run multiple AI agents in parallel with git worktree isolation.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Bar -->
        <div class="status-bar">
            <span>Ready</span>
            <span>OpenOhMyCode Portable v2.0</span>
        </div>
    </div>
</div>

<script language="VBScript">
Dim fso, shell
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")

Function GetPortableRoot()
    Dim path
    path = Replace(location.pathname, "/", "\")
    path = Replace(path, "OpenOhMyCode.hta", "")
    If Left(path, 1) = "\" Then path = Mid(path, 2)
    GetPortableRoot = path
End Function

Function RunCommand(cmd)
    Dim exec, output
    On Error Resume Next
    Set exec = shell.Exec(cmd)
    If Err.Number <> 0 Then
        RunCommand = "Error: " & Err.Description
        Exit Function
    End If
    output = ""
    Do While exec.Status = 0 Or Not exec.StdOut.AtEndOfStream
        If Not exec.StdOut.AtEndOfStream Then
            output = output & exec.StdOut.ReadLine & vbCrLf
        End If
    Loop
    Do While Not exec.StdErr.AtEndOfStream
        output = output & exec.StdErr.ReadLine & vbCrLf
    Loop
    RunCommand = output
End Function

Function PathExists(path)
    PathExists = fso.FolderExists(path) Or fso.FileExists(path)
End Function

Function BrowseFolder()
    Dim folderDialog, result
    On Error Resume Next
    Set folderDialog = CreateObject("Shell.Application")
    Set result = folderDialog.BrowseForFolder(0, "Select Project Folder", 0)
    If Err.Number = 0 And Not result Is Nothing Then
        BrowseFolder = result.Self.Path
    Else
        BrowseFolder = ""
    End If
End Function
</script>

<script language="JScript">
var portableRoot = '';
var nodeHome = '';
var appHome = '';
var configDir = '';
var browsersPath = '';
var currentOutput = 'output';

function init() {
    portableRoot = GetPortableRoot();
    if (portableRoot.charAt(portableRoot.length - 1) == '\\') {
        portableRoot = portableRoot.substring(0, portableRoot.length - 1);
    }
    nodeHome = portableRoot + '\\nodejs';
    appHome = portableRoot + '\\app';
    configDir = portableRoot + '\\config';
    browsersPath = portableRoot + '\\browsers';
    
    document.getElementById('pathRoot').innerText = portableRoot;
    document.getElementById('pathNode').innerText = nodeHome;
    document.getElementById('pathApp').innerText = appHome;
    document.getElementById('pathConfig').innerText = configDir;
    document.getElementById('pathBrowsers').innerText = browsersPath;
    
    checkPlaywrightStatus();
}

function log(msg, type) {
    var output = document.getElementById(currentOutput);
    var line = document.createElement('div');
    if (type) line.className = type;
    line.innerText = msg;
    output.appendChild(line);
    output.scrollTop = output.scrollHeight;
}

function clearOutput() {
    document.getElementById(currentOutput).innerHTML = '';
}

function logInfo(msg) { log('[INFO] ' + msg, 'info'); }
function logSuccess(msg) { log('[OK] ' + msg, 'success'); }
function logError(msg) { log('[ERROR] ' + msg, 'error'); }
function logWarn(msg) { log('[WARN] ' + msg, 'warn'); }

function showPanel(name) {
    var panels = ['main', 'worktree', 'playwright', 'settings'];
    var titles = { main: 'Start', worktree: 'Worktrees', playwright: 'Playwright', settings: 'Settings' };
    var outputs = { main: 'output', worktree: 'output-wt', playwright: 'output-pw', settings: 'output' };
    
    for (var i = 0; i < panels.length; i++) {
        document.getElementById('panel-' + panels[i]).className = 'panel';
        document.getElementById('panel-' + panels[i]).previousSibling.className = 'sidebar-item';
    }
    
    document.getElementById('panel-' + name).className = 'panel active';
    event.srcElement.className = 'sidebar-item active';
    document.getElementById('headerTitle').innerText = titles[name];
    currentOutput = outputs[name];
}

function browseFolder() {
    var folder = BrowseFolder();
    if (folder) document.getElementById('projectPath').value = folder;
}

function runOpenCode() {
    var path = document.getElementById('projectPath').value;
    if (!path) { logError('Enter project path'); return; }
    if (!PathExists(path)) { logError('Folder not found'); return; }
    
    logInfo('Starting OpenCode...');
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\opencode-ai\\bin\\opencode"';
    shell.CurrentDirectory = path;
    shell.Run('cmd /k "' + cmd + '"', 1, false);
    logSuccess('Started');
}

function openInCurrentFolder() {
    document.getElementById('projectPath').value = portableRoot;
}

function openConfig() {
    shell.Run('explorer "' + configDir + '"', 1, false);
}

function checkNode() {
    logInfo('Checking...');
    if (PathExists(nodeHome + '\\node.exe')) {
        logSuccess('Found: ' + nodeHome + '\\node.exe');
    } else {
        logError('Not found');
    }
}

function checkOpenCode() {
    logInfo('Checking...');
    if (PathExists(appHome + '\\node_modules\\opencode-ai\\bin\\opencode')) {
        logSuccess('Found');
    } else {
        logError('Not found');
    }
}

function createWorktree() {
    var name = document.getElementById('wtName').value;
    var agent = document.getElementById('wtAgent').value;
    if (!name) { logError('Enter name'); return; }
    
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree create ' + name;
    if (agent) cmd += ' --agent ' + agent;
    log(RunCommand(cmd));
}

function listWorktrees() {
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree list';
    log(RunCommand(cmd));
}

function showStatus() {
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree status';
    log(RunCommand(cmd));
}

function checkConflicts() {
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree status --conflicts';
    log(RunCommand(cmd));
}

function mergeWorktree() {
    var name = document.getElementById('wtMergeName').value;
    if (!name) { logError('Enter name'); return; }
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree merge ' + name + ' --yes';
    log(RunCommand(cmd));
}

function deleteWorktree() {
    var name = document.getElementById('wtMergeName').value;
    if (!name) { logError('Enter name'); return; }
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup ' + name + ' --force';
    log(RunCommand(cmd));
}

function cleanupMerged() {
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup --merged --force';
    log(RunCommand(cmd));
}

function cleanupAll() {
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup --all --force';
    log(RunCommand(cmd));
}

function checkPlaywrightStatus() {
    var npmStatus = document.getElementById('pwNpmStatus');
    var npmText = document.getElementById('pwNpmText');
    
    if (PathExists(appHome + '\\node_modules\\playwright')) {
        npmStatus.className = 'status-dot ok';
        npmText.innerText = 'Playwright npm: Installed';
    } else {
        npmStatus.className = 'status-dot warn';
        npmText.innerText = 'Playwright npm: Not installed';
    }
    
    var browserStatus = document.getElementById('pwBrowserStatus');
    var browserText = document.getElementById('pwBrowserText');
    
    if (PathExists(browsersPath)) {
        browserStatus.className = 'status-dot ok';
        browserText.innerText = 'Chromium: Installed';
    } else {
        browserStatus.className = 'status-dot warn';
        browserText.innerText = 'Chromium: Not installed';
    }
}

function installPlaywright() {
    logInfo('Installing...');
    var cmd = 'cmd /c "set PLAYWRIGHT_BROWSERS_PATH=' + browsersPath + ' && "' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\playwright\\cli.js" install chromium"';
    log(RunCommand(cmd));
    checkPlaywrightStatus();
}

function checkPlaywright() {
    logInfo('Checking...');
    checkPlaywrightStatus();
    if (PathExists(appHome + '\\node_modules\\playwright')) logSuccess('npm: OK');
    else logWarn('npm: Missing');
    if (PathExists(browsersPath)) logSuccess('Chromium: OK');
    else logWarn('Chromium: Missing');
}

window.onload = init;
</script>
</body>
</html>
