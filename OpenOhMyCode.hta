<!DOCTYPE html>
<html>
<head>
<title>OpenOhMyCode Portable</title>
<HTA:APPLICATION
    ID="OpenOhMyCode"
    APPLICATIONNAME="OpenOhMyCode Portable"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    CONTEXTMENU="yes"
    ICON=""
    INNERBORDER="no"
    MAXIMIZEBUTTON="yes"
    MINIMIZEBUTTON="yes"
    NAVIGABLE="no"
    SCROLL="no"
    SCROLLFLAT="no"
    SELECTION="no"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    VERSION="2.0"
    WINDOWSTATE="normal"
/>
<style>
/* ========== CSS Reset & Base ========== */
* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
    /* VS Code Dark Theme Colors */
    --bg-primary: #1e1e1e;
    --bg-secondary: #252526;
    --bg-tertiary: #2d2d2d;
    --bg-hover: #37373d;
    --bg-active: #094771;
    
    --border-color: #3c3c3c;
    --border-focus: #007acc;
    
    --text-primary: #cccccc;
    --text-secondary: #858585;
    --text-active: #ffffff;
    
    --accent-blue: #007acc;
    --accent-green: #4ec9b0;
    --accent-orange: #ce9178;
    --accent-yellow: #dcdcaa;
    --accent-red: #f14c4c;
    --accent-purple: #c586c0;
    
    --btn-primary: #0e639c;
    --btn-primary-hover: #1177bb;
    --btn-secondary: #3c3c3c;
    --btn-secondary-hover: #4e4e4e;
    --btn-danger: #c42b1c;
    --btn-danger-hover: #d63a2a;
    --btn-success: #1c6e1c;
    --btn-success-hover: #2d8c2d;
    
    /* Spacing */
    --spacing-xs: 4px;
    --spacing-sm: 8px;
    --spacing-md: 12px;
    --spacing-lg: 16px;
    --spacing-xl: 24px;
    
    /* Typography */
    --font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'Consolas', 'Courier New', monospace;
    --font-size-xs: 11px;
    --font-size-sm: 12px;
    --font-size-md: 13px;
    --font-size-lg: 14px;
    --font-size-xl: 16px;
    
    /* Layout */
    --sidebar-width: 48px;
    --header-height: 35px;
}

html, body {
    height: 100%;
    overflow: hidden;
}

body {
    font-family: var(--font-family);
    font-size: var(--font-size-md);
    background: var(--bg-primary);
    color: var(--text-primary);
    display: flex;
}

/* ========== Layout ========== */
.app {
    display: flex;
    width: 100%;
    height: 100%;
}

/* ========== Sidebar ========== */
.sidebar {
    width: var(--sidebar-width);
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    padding: var(--spacing-sm) 0;
}

.sidebar-item {
    width: var(--sidebar-width);
    height: var(--sidebar-width);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-secondary);
    position: relative;
    transition: color 0.15s;
}

.sidebar-item:hover {
    color: var(--text-primary);
}

.sidebar-item.active {
    color: var(--text-active);
}

.sidebar-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--accent-blue);
}

.sidebar-icon {
    font-size: 24px;
    font-weight: 300;
    opacity: 0.9;
}

.sidebar-item:hover .sidebar-icon,
.sidebar-item.active .sidebar-icon {
    opacity: 1;
}

/* ========== Main Content ========== */
.main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

/* ========== Header ========== */
.header {
    height: var(--header-height);
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-lg);
}

.header-title {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* ========== Content Area ========== */
.content-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.panel {
    display: none;
    flex: 1;
    padding: var(--spacing-xl);
    overflow-y: auto;
}

.panel.active {
    display: block;
}

/* ========== Sections ========== */
.section {
    margin-bottom: var(--spacing-xl);
}

.section-header {
    display: flex;
    align-items: center;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--border-color);
}

.section-title {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* ========== Form Elements ========== */
.form-row {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
    align-items: flex-end;
}

.form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
}

.form-group.compact {
    flex: 0 0 auto;
}

.form-label {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
    font-weight: 500;
}

.form-input,
.form-select {
    height: 28px;
    padding: 0 var(--spacing-md);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 2px;
    color: var(--text-primary);
    font-family: var(--font-family);
    font-size: var(--font-size-md);
    outline: none;
    transition: border-color 0.15s;
}

.form-input:focus,
.form-select:focus {
    border-color: var(--border-focus);
}

.form-input::placeholder {
    color: var(--text-secondary);
}

.form-select {
    cursor: pointer;
}

/* ========== Buttons ========== */
.btn {
    height: 28px;
    padding: 0 var(--spacing-lg);
    border: none;
    border-radius: 2px;
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    transition: background 0.15s;
    white-space: nowrap;
}

.btn-primary {
    background: var(--btn-primary);
    color: #fff;
}

.btn-primary:hover {
    background: var(--btn-primary-hover);
}

.btn-secondary {
    background: var(--btn-secondary);
    color: var(--text-primary);
}

.btn-secondary:hover {
    background: var(--btn-secondary-hover);
}

.btn-success {
    background: var(--btn-success);
    color: #fff;
}

.btn-success:hover {
    background: var(--btn-success-hover);
}

.btn-danger {
    background: var(--btn-danger);
    color: #fff;
}

.btn-danger:hover {
    background: var(--btn-danger-hover);
}

.btn-icon {
    width: 28px;
    padding: 0;
    justify-content: center;
}

.btn-group {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
}

/* ========== Button Grid ========== */
.btn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--spacing-sm);
}

.btn-grid .btn {
    width: 100%;
    justify-content: flex-start;
}

/* ========== Status Bar ========== */
.status-bar {
    display: flex;
    gap: var(--spacing-xl);
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    font-size: var(--font-size-xs);
}

.status-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
}

.status-dot.ok { background: var(--accent-green); }
.status-dot.warn { background: var(--accent-orange); }
.status-dot.error { background: var(--accent-red); }
.status-dot.info { background: var(--accent-blue); }

/* ========== Output Panel ========== */
.output-panel {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 2px;
    margin-top: var(--spacing-lg);
}

.output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-color);
}

.output-title {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.output-content {
    height: 150px;
    overflow-y: auto;
    padding: var(--spacing-md);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-all;
}

.output-line { margin: 0; }

.output-line.success { color: var(--accent-green); }
.output-line.error { color: var(--accent-red); }
.output-line.info { color: var(--accent-blue); }
.output-line.warn { color: var(--accent-orange); }

/* ========== Info List ========== */
.info-list {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 2px;
}

.info-item {
    display: flex;
    padding: var(--spacing-sm) var(--spacing-md);
    border-bottom: 1px solid var(--border-color);
}

.info-item:last-child {
    border-bottom: none;
}

.info-label {
    width: 120px;
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
}

.info-value {
    flex: 1;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    word-break: break-all;
}

/* ========== Card ========== */
.card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 2px;
    padding: var(--spacing-lg);
}

.card + .card {
    margin-top: var(--spacing-md);
}

.card-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
}

.card-text {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    line-height: 1.5;
}

/* ========== Utility ========== */
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.text-muted { color: var(--text-secondary); }
.text-sm { font-size: var(--font-size-sm); }
</style>
</head>
<body>
<div class="app">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-item active" onclick="showPanel('main')" title="Main">
            <span class="sidebar-icon">&#9654;</span>
        </div>
        <div class="sidebar-item" onclick="showPanel('worktree')" title="Worktrees">
            <span class="sidebar-icon">&#9874;</span>
        </div>
        <div class="sidebar-item" onclick="showPanel('playwright')" title="Playwright">
            <span class="sidebar-icon">&#9881;</span>
        </div>
        <div class="sidebar-item" onclick="showPanel('settings')" title="Settings">
            <span class="sidebar-icon">&#9881;</span>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main">
        <!-- Header -->
        <div class="header">
            <span class="header-title" id="headerTitle">Start</span>
        </div>

        <!-- Content Area -->
        <div class="content-area">
            <!-- Main Panel -->
            <div id="panel-main" class="panel active">
                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Start OpenCode</span>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Project Folder</label>
                            <input type="text" class="form-input" id="projectPath" placeholder="Enter path or browse...">
                        </div>
                        <div class="form-group compact">
                            <label class="form-label">&nbsp;</label>
                            <button class="btn btn-secondary" onclick="browseFolder()">Browse</button>
                        </div>
                        <div class="form-group compact">
                            <label class="form-label">&nbsp;</label>
                            <button class="btn btn-primary" onclick="runOpenCode()">Start</button>
                        </div>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Quick Actions</span>
                    </div>
                    <div class="btn-grid">
                        <button class="btn btn-secondary" onclick="openInCurrentFolder()">This Folder</button>
                        <button class="btn btn-secondary" onclick="openConfig()">Open Config</button>
                        <button class="btn btn-secondary" onclick="checkNode()">Check Node.js</button>
                        <button class="btn btn-secondary" onclick="checkOpenCode()">Check OpenCode</button>
                    </div>
                </div>

                <div class="output-panel">
                    <div class="output-header">
                        <span class="output-title">Output</span>
                        <button class="btn btn-secondary btn-icon" onclick="clearOutput()" title="Clear">&#10006;</button>
                    </div>
                    <div class="output-content" id="output"></div>
                </div>
            </div>

            <!-- Worktree Panel -->
            <div id="panel-worktree" class="panel">
                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Create Worktree</span>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-input" id="wtName" placeholder="feature-auth">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Agent</label>
                            <select class="form-select" id="wtAgent">
                                <option value="">None</option>
                                <option value="sisyphus">sisyphus</option>
                                <option value="hephaestus">hephaestus</option>
                                <option value="oracle">oracle</option>
                                <option value="librarian">librarian</option>
                                <option value="explore">explore</option>
                                <option value="frontend-ui-ux">frontend-ui-ux</option>
                            </select>
                        </div>
                        <div class="form-group compact">
                            <label class="form-label">&nbsp;</label>
                            <button class="btn btn-success" onclick="createWorktree()">Create</button>
                        </div>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Actions</span>
                    </div>
                    <div class="btn-grid">
                        <button class="btn btn-primary" onclick="listWorktrees()">List All</button>
                        <button class="btn btn-primary" onclick="showStatus()">Status</button>
                        <button class="btn btn-secondary" onclick="checkConflicts()">Check Conflicts</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Merge / Delete</span>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Worktree Name</label>
                            <input type="text" class="form-input" id="wtMergeName" placeholder="feature-auth">
                        </div>
                        <div class="form-group compact">
                            <label class="form-label">&nbsp;</label>
                            <button class="btn btn-secondary" onclick="mergeWorktree()">Merge</button>
                        </div>
                        <div class="form-group compact">
                            <label class="form-label">&nbsp;</label>
                            <button class="btn btn-danger" onclick="deleteWorktree()">Delete</button>
                        </div>
                    </div>
                    <div class="btn-group mt-md">
                        <button class="btn btn-secondary" onclick="cleanupMerged()">Cleanup Merged</button>
                        <button class="btn btn-danger" onclick="cleanupAll()">Cleanup All</button>
                    </div>
                </div>

                <div class="output-panel">
                    <div class="output-header">
                        <span class="output-title">Output</span>
                        <button class="btn btn-secondary btn-icon" onclick="clearOutput()" title="Clear">&#10006;</button>
                    </div>
                    <div class="output-content" id="output-wt"></div>
                </div>
            </div>

            <!-- Playwright Panel -->
            <div id="panel-playwright" class="panel">
                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Browser Automation</span>
                    </div>
                    <div class="card">
                        <div class="card-title">Playwright with Chromium</div>
                        <div class="card-text">
                            Install Chromium browser for automated testing and browser tasks.<br>
                            Download size: ~135MB
                        </div>
                    </div>
                    <div class="btn-group mt-lg">
                        <button class="btn btn-success" onclick="installPlaywright()">Install Chromium</button>
                        <button class="btn btn-secondary" onclick="checkPlaywright()">Check Status</button>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Status</span>
                    </div>
                    <div class="status-bar" style="flex-direction: column; align-items: flex-start; gap: 12px; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 2px;">
                        <div class="status-item">
                            <span class="status-dot" id="pwNpmStatus"></span>
                            <span id="pwNpmText">Playwright npm: Checking...</span>
                        </div>
                        <div class="status-item">
                            <span class="status-dot" id="pwBrowserStatus"></span>
                            <span id="pwBrowserText">Chromium: Checking...</span>
                        </div>
                    </div>
                </div>

                <div class="output-panel">
                    <div class="output-header">
                        <span class="output-title">Output</span>
                        <button class="btn btn-secondary btn-icon" onclick="clearOutput()" title="Clear">&#10006;</button>
                    </div>
                    <div class="output-content" id="output-pw"></div>
                </div>
            </div>

            <!-- Settings Panel -->
            <div id="panel-settings" class="panel">
                <div class="section">
                    <div class="section-header">
                        <span class="section-title">Paths</span>
                    </div>
                    <div class="info-list">
                        <div class="info-item">
                            <span class="info-label">Root</span>
                            <span class="info-value" id="pathRoot"></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Node.js</span>
                            <span class="info-value" id="pathNode"></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">App</span>
                            <span class="info-value" id="pathApp"></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Config</span>
                            <span class="info-value" id="pathConfig"></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Browsers</span>
                            <span class="info-value" id="pathBrowsers"></span>
                        </div>
                    </div>
                </div>

                <div class="section">
                    <div class="section-header">
                        <span class="section-title">About</span>
                    </div>
                    <div class="card">
                        <div class="card-title">OpenOhMyCode Portable</div>
                        <div class="card-text">
                            Version 2.0<br>
                            Portable OpenCode + oh-my-opencode bundle<br><br>
                            Run multiple AI agents in parallel with git worktree isolation.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Bar -->
        <div class="status-bar">
            <div class="status-item">
                <span class="status-dot info"></span>
                <span>Ready</span>
            </div>
            <div class="status-item">
                <span>OpenOhMyCode Portable v2.0</span>
            </div>
        </div>
    </div>
</div>

<script language="VBScript">
' VBScript for file system operations
Dim fso, shell
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")

Function GetPortableRoot()
    Dim path
    path = Replace(location.pathname, "/", "\")
    path = Replace(path, "OpenOhMyCode.hta", "")
    If Left(path, 1) = "\" Then path = Mid(path, 2)
    GetPortableRoot = path
End Function

Function RunCommand(cmd)
    Dim exec, output
    On Error Resume Next
    Set exec = shell.Exec(cmd)
    If Err.Number <> 0 Then
        RunCommand = "Error: " & Err.Description
        Exit Function
    End If
    
    output = ""
    Do While exec.Status = 0 Or Not exec.StdOut.AtEndOfStream
        If Not exec.StdOut.AtEndOfStream Then
            output = output & exec.StdOut.ReadLine & vbCrLf
        End If
    Loop
    
    Do While Not exec.StdErr.AtEndOfStream
        output = output & exec.StdErr.ReadLine & vbCrLf
    Loop
    
    RunCommand = output
End Function

Function PathExists(path)
    PathExists = fso.FolderExists(path) Or fso.FileExists(path)
End Function

Function BrowseFolder()
    Dim folderDialog, result
    On Error Resume Next
    Set folderDialog = CreateObject("Shell.Application")
    Set result = folderDialog.BrowseForFolder(0, "Select Project Folder", 0)
    If Err.Number = 0 And Not result Is Nothing Then
        BrowseFolder = result.Self.Path
    Else
        BrowseFolder = ""
    End If
End Function
</script>

<script language="JScript">
var portableRoot = '';
var nodeHome = '';
var appHome = '';
var configDir = '';
var browsersPath = '';
var currentOutput = 'output';

function init() {
    portableRoot = GetPortableRoot();
    if (portableRoot.charAt(portableRoot.length - 1) == '\\') {
        portableRoot = portableRoot.substring(0, portableRoot.length - 1);
    }
    
    nodeHome = portableRoot + '\\nodejs';
    appHome = portableRoot + '\\app';
    configDir = portableRoot + '\\config';
    browsersPath = portableRoot + '\\browsers';
    
    document.getElementById('pathRoot').innerText = portableRoot;
    document.getElementById('pathNode').innerText = nodeHome;
    document.getElementById('pathApp').innerText = appHome;
    document.getElementById('pathConfig').innerText = configDir;
    document.getElementById('pathBrowsers').innerText = browsersPath;
    
    checkPlaywrightStatus();
}

function log(msg, type) {
    var output = document.getElementById(currentOutput);
    var line = document.createElement('div');
    line.className = 'output-line' + (type ? ' ' + type : '');
    line.innerText = msg;
    output.appendChild(line);
    output.scrollTop = output.scrollHeight;
}

function clearOutput() {
    document.getElementById(currentOutput).innerHTML = '';
}

function logInfo(msg) { log('[INFO] ' + msg, 'info'); }
function logSuccess(msg) { log('[OK] ' + msg, 'success'); }
function logError(msg) { log('[ERROR] ' + msg, 'error'); }
function logWarn(msg) { log('[WARN] ' + msg, 'warn'); }

function showPanel(name) {
    var panels = document.querySelectorAll('.panel');
    var items = document.querySelectorAll('.sidebar-item');
    var titles = { main: 'Start', worktree: 'Worktrees', playwright: 'Playwright', settings: 'Settings' };
    var outputs = { main: 'output', worktree: 'output-wt', playwright: 'output-pw', settings: 'output' };
    
    for (var i = 0; i < panels.length; i++) {
        panels[i].className = 'panel';
    }
    for (var i = 0; i < items.length; i++) {
        items[i].className = 'sidebar-item';
    }
    
    document.getElementById('panel-' + name).className = 'panel active';
    event.currentTarget.className = 'sidebar-item active';
    document.getElementById('headerTitle').innerText = titles[name];
    currentOutput = outputs[name];
}

function browseFolder() {
    var folder = BrowseFolder();
    if (folder) {
        document.getElementById('projectPath').value = folder;
    }
}

function runOpenCode() {
    var path = document.getElementById('projectPath').value;
    if (!path) {
        logError('Please enter a project folder path');
        return;
    }
    
    if (!PathExists(path)) {
        logError('Folder not found: ' + path);
        return;
    }
    
    logInfo('Starting OpenCode in: ' + path);
    
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\opencode-ai\\bin\\opencode"';
    shell.CurrentDirectory = path;
    shell.Run('cmd /k "' + cmd + '"', 1, false);
    
    logSuccess('OpenCode started in new window');
}

function openInCurrentFolder() {
    document.getElementById('projectPath').value = portableRoot;
    logInfo('Set path to: ' + portableRoot);
}

function openConfig() {
    logInfo('Opening config folder...');
    shell.Run('explorer "' + configDir + '"', 1, false);
    logSuccess('Config folder opened');
}

function checkNode() {
    logInfo('Checking Node.js...');
    if (PathExists(nodeHome + '\\node.exe')) {
        logSuccess('Node.js found');
        var output = RunCommand('"' + nodeHome + '\\node.exe" --version');
        log('Version: ' + output.replace(/\r?\n/g, ''));
    } else {
        logError('Node.js not found');
    }
}

function checkOpenCode() {
    logInfo('Checking OpenCode...');
    var ocPath = appHome + '\\node_modules\\opencode-ai\\bin\\opencode';
    if (PathExists(ocPath)) {
        logSuccess('OpenCode found');
    } else {
        logError('OpenCode not found');
    }
}

function createWorktree() {
    var name = document.getElementById('wtName').value;
    var agent = document.getElementById('wtAgent').value;
    
    if (!name) {
        logError('Please enter a worktree name');
        return;
    }
    
    logInfo('Creating worktree: ' + name);
    
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree create ' + name;
    if (agent) cmd += ' --agent ' + agent;
    
    var output = RunCommand(cmd);
    log(output);
}

function listWorktrees() {
    logInfo('Listing worktrees...');
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree list';
    var output = RunCommand(cmd);
    log(output);
}

function showStatus() {
    logInfo('Getting status...');
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree status';
    var output = RunCommand(cmd);
    log(output);
}

function checkConflicts() {
    logInfo('Checking conflicts...');
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree status --conflicts';
    var output = RunCommand(cmd);
    log(output);
}

function mergeWorktree() {
    var name = document.getElementById('wtMergeName').value;
    if (!name) {
        logError('Enter worktree name');
        return;
    }
    
    logInfo('Merging: ' + name);
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree merge ' + name + ' --yes';
    var output = RunCommand(cmd);
    log(output);
}

function deleteWorktree() {
    var name = document.getElementById('wtMergeName').value;
    if (!name) {
        logError('Enter worktree name');
        return;
    }
    
    logInfo('Deleting: ' + name);
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup ' + name + ' --force';
    var output = RunCommand(cmd);
    log(output);
}

function cleanupMerged() {
    logInfo('Cleaning merged worktrees...');
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup --merged --force';
    var output = RunCommand(cmd);
    log(output);
}

function cleanupAll() {
    logWarn('Cleaning ALL worktrees...');
    var cmd = '"' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\oh-my-opencode\\dist\\cli\\index.js" worktree cleanup --all --force';
    var output = RunCommand(cmd);
    log(output);
}

function checkPlaywrightStatus() {
    var npmStatus = document.getElementById('pwNpmStatus');
    var npmText = document.getElementById('pwNpmText');
    var pwPath = appHome + '\\node_modules\\playwright';
    
    if (PathExists(pwPath)) {
        npmStatus.className = 'status-dot ok';
        npmText.innerText = 'Playwright npm: Installed';
    } else {
        npmStatus.className = 'status-dot warn';
        npmText.innerText = 'Playwright npm: Not installed';
    }
    
    var browserStatus = document.getElementById('pwBrowserStatus');
    var browserText = document.getElementById('pwBrowserText');
    
    if (PathExists(browsersPath)) {
        browserStatus.className = 'status-dot ok';
        browserText.innerText = 'Chromium: Installed';
    } else {
        browserStatus.className = 'status-dot warn';
        browserText.innerText = 'Chromium: Not installed';
    }
}

function installPlaywright() {
    logInfo('Installing Playwright with Chromium...');
    logInfo('Download size: ~135MB');
    
    var cmd = 'cmd /c "set PLAYWRIGHT_BROWSERS_PATH=' + browsersPath + ' && "' + nodeHome + '\\node.exe" "' + appHome + '\\node_modules\\playwright\\cli.js" install chromium"';
    
    logInfo('Running install...');
    var output = RunCommand(cmd);
    log(output);
    
    checkPlaywrightStatus();
}

function checkPlaywright() {
    logInfo('Checking Playwright...');
    
    var pwPath = appHome + '\\node_modules\\playwright';
    if (PathExists(pwPath)) {
        logSuccess('Playwright npm: Found');
    } else {
        logWarn('Playwright npm: Not found');
    }
    
    if (PathExists(browsersPath)) {
        logSuccess('Chromium: Found');
    } else {
        logWarn('Chromium: Not found');
    }
    
    checkPlaywrightStatus();
}

window.onload = init;
</script>
</body>
</html>
